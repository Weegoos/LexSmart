# PostgreSQL
POSTGRES_USER=lexsmart
POSTGRES_PASSWORD=lexsmart_secret
POSTGRES_DB=lexsmart
DATABASE_URL=postgresql+asyncpg://lexsmart:lexsmart_secret@postgres:5432/lexsmart

# JWT
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# LLM (Alem AI - OpenAI-compatible)
OPENAI_API_KEY=sk-your-llm-key
OPENAI_BASE_URL=https://llm.alem.ai/v1
LLM_MODEL=alemllm

# Embeddings (Alem AI - separate key)
EMBED_API_KEY=sk-your-embed-key
EMBED_BASE_URL=https://llm.alem.ai/v1
EMBED_MODEL=text-1024

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
